APP_NAME=CertVerify
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://certify.dostcaraga.ph
DOCKER_APP_URL=https://certify.dostcaraga.ph
TRUSTED_PROXIES=*
APP_BIND=127.0.0.1
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=certverify
DB_USERNAME=certverify_user
DB_PASSWORD=change-this-password
DB_SSLMODE=prefer
DB_FORWARD_BIND=127.0.0.1
DB_FORWARD_PORT=54329

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer-user
MAIL_PASSWORD=mailer-password
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

BACKUP_TARGET_DIR=
DB_BACKUP_CRON_SCHEDULE=0 */2 * * *
DB_BACKUP_KEEP_MIN_FILES=10
DB_BACKUP_MAX_FILES=10
DB_BACKUP_RUN_ON_START=true
APP_STORAGE_BACKUP_CRON_SCHEDULE=0 */2 * * *
APP_STORAGE_BACKUP_KEEP_MIN_FILES=10
APP_STORAGE_BACKUP_MAX_FILES=10
APP_STORAGE_BACKUP_RUN_ON_START=true
DB_BACKUP_GPG_ENABLED=false
DB_BACKUP_GPG_PASSPHRASE=
DB_BACKUP_GPG_RECIPIENT=
DB_BACKUP_KEEP_PLAIN=false
BACKUP_TIMEZONE=Asia/Manila
BACKUP_TZ_LABEL=PHT
OFFSITE_BACKUP_ENABLED=false
OFFSITE_BACKUP_METHOD=rsync
OFFSITE_BACKUP_HOST=
OFFSITE_BACKUP_PORT=22
OFFSITE_BACKUP_USER=
OFFSITE_BACKUP_PATH=
OFFSITE_BACKUP_SSH_KEY=
OFFSITE_BACKUP_KEEP_LOCAL=false

CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_METRICS=0.0.0.0:2000

CERT_RD_ESIGN_ENABLED=true
CERT_RD_ESIGN_PATH_OVERRIDE=
CERT_RD_ESIGN_PATH=images/regional-director-signature.png
CERT_RD_ESIGN_X=
CERT_RD_ESIGN_Y=
CERT_RD_ESIGN_WIDTH=52
CERT_RD_ESIGN_HEIGHT=18

# Facebook Messenger alert for endorsement submissions
FB_MESSENGER_ENABLED=false
FB_MESSENGER_NOTIFY_ON_EVERY_ENDORSE=true
FB_MESSENGER_BULK_THRESHOLD=50
FB_MESSENGER_PAGE_ACCESS_TOKEN=
FB_MESSENGER_RD_PSID=
FB_MESSENGER_APPROVALS_URL=
FB_MESSENGER_GRAPH_API_VERSION=v22.0

# Telegram bot alert for endorsement submissions
TG_BOT_ENABLED=false
TG_NOTIFY_ON_EVERY_ENDORSE=true
TG_BULK_THRESHOLD=50
TG_BOT_TOKEN=
TG_RD_CHAT_ID=
TG_WEBHOOK_SECRET=
