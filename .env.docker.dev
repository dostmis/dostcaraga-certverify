APP_NAME="DOST CERTiFY - Dev"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8082
DOCKER_APP_URL=http://localhost:8082
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=certverify_dev
DB_USERNAME=certverify_dev_user
DB_PASSWORD=dev_secret
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_BACKEND_URL=http://localhost:8082

# Development ports (won't conflict with production)
DEV_APP_PORT=8082
DEV_VITE_PORT=5173
DEV_DB_PORT=54330

# Disable backups in dev
BACKUP_TARGET_DIR=
DB_BACKUP_CRON_SCHEDULE=
DB_BACKUP_KEEP_MIN_FILES=0
DB_BACKUP_MAX_FILES=0
DB_BACKUP_RUN_ON_START=false
APP_STORAGE_BACKUP_CRON_SCHEDULE=
APP_STORAGE_BACKUP_KEEP_MIN_FILES=0
APP_STORAGE_BACKUP_MAX_FILES=0
APP_STORAGE_BACKUP_RUN_ON_START=false

OFFSITE_BACKUP_ENABLED=false

CERT_RD_ESIGN_ENABLED=true
CERT_RD_ESIGN_PATH_OVERRIDE=
CERT_RD_ESIGN_PATH=images/regional-director-signature.png
CERT_RD_ESIGN_X=
CERT_RD_ESIGN_Y=
CERT_RD_ESIGN_Y_OFFSET=4
CERT_RD_ESIGN_WIDTH=96
CERT_RD_ESIGN_HEIGHT=32

FB_MESSENGER_ENABLED=false
FB_MESSENGER_NOTIFY_ON_EVERY_ENDORSE=true
FB_MESSENGER_BULK_THRESHOLD=50
FB_MESSENGER_PAGE_ACCESS_TOKEN=
FB_MESSENGER_RD_PSID=
FB_MESSENGER_APPROVALS_URL=
FB_MESSENGER_GRAPH_API_VERSION=v22.0

TG_BOT_ENABLED=false
TG_NOTIFY_ON_EVERY_ENDORSE=true
TG_BULK_THRESHOLD=50
TG_BOT_TOKEN=
TG_CHAT_IDS=
TG_WEBHOOK_SECRET=