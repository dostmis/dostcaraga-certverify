# Hedera bridge secrets — THIS FILE IS THE ONLY PLACE THE KEY LIVES.
# Copy to hedera/.env and fill in. Never commit hedera/.env.
#
# From https://portal.hedera.com testnet account:
#   - HEDERA_ACCOUNT_ID  = the "Account ID"           (e.g. 0.0.1234567)
#   - HEDERA_PRIVATE_KEY = the "HEX Encoded Private Key"
#   (ignore the EVM Address — it is for smart contracts, not HCS)

HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=
HEDERA_PRIVATE_KEY=

# Set after running: php artisan hedera:create-topic
HEDERA_TOPIC_ID=

# Bind localhost-only. Laravel reaches this at HEDERA_BRIDGE_URL.
HOST=127.0.0.1
PORT=3001
